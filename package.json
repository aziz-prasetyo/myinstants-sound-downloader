{
	"name": "myinstants-sound-downloader",
	"module": "index.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"start": "bun run src/index.ts",
		"check": "prettier --check .",
		"format": "prettier --write .",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"fix": "bun format && bun lint:fix",
		"build:win-x64": "bun build src/index.ts --compile --target=bun-windows-x64 --outfile dist/sound-downloader-windows-x64.exe",
		"build:linux-x64": "bun build src/index.ts --compile --target=bun-linux-x64 --outfile dist/sound-downloader-linux-x64",
		"build:linux-arm64": "bun build src/index.ts --compile --target=bun-linux-arm64 --outfile dist/sound-downloader-linux-arm64",
		"build:mac-x64": "bun build src/index.ts --compile --target=bun-darwin-x64 --outfile dist/sound-downloader-mac-x64",
		"build:mac-arm64": "bun build src/index.ts --compile --target=bun-darwin-arm64 --outfile dist/sound-downloader-mac-arm64",
		"build:release": "bun run build:win-x64 && bun run build:linux-x64 && bun run build:linux-arm64 && bun run build:mac-x64 && bun run build:mac-arm64"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@eslint/markdown": "^8.0.1",
		"@types/bun": "latest",
		"eslint": "^10.2.1",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^17.5.0",
		"prettier": "^3.8.3",
		"typescript-eslint": "^8.59.0"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"@clack/prompts": "^1.2.0",
		"picocolors": "^1.1.1",
		"valibot": "^1.3.1"
	}
}
